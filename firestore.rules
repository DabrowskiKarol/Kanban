rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsProfile(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function boardVisible(boardId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/boards/$(boardId)) &&
        (
          request.auth.uid in get(/databases/$(database)/documents/boards/$(boardId)).data.memberIds ||
          request.auth.token.email in get(/databases/$(database)/documents/boards/$(boardId)).data.memberEmails
        );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if ownsProfile(userId);
      allow update, delete: if ownsProfile(userId);
    }

    match /boards/{boardId} {
      allow read: if boardVisible(boardId);
      allow create: if signedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.auth.token.email in request.resource.data.memberEmails &&
        request.auth.uid in request.resource.data.memberIds;
      allow update, delete: if boardVisible(boardId);

      match /columns/{columnId} {
        allow read, write: if boardVisible(boardId);
      }

      match /tasks/{taskId} {
        allow read, write: if boardVisible(boardId);
      }

      match /activity/{activityId} {
        allow read, write: if boardVisible(boardId);
      }
    }
  }
}
